{
  "installCommand": "npm install && chmod +x ./node_modules/.bin/ng",
  "buildCommand": "node ./node_modules/@angular/cli/bin/ng.js build --configuration production",
  "outputDirectory": "dist/portfolio/browser",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
